# Generated QA reports (HTML, JSON, screenshots, traces) — keep folder, ignore contents
qa-reports/*
!qa-reports/.gitkeep

# Dependencies
node_modules/

# Environment
.env
.env.local
**/.env

# Build output
web/dist/
# Writable runtime dirs (keep skeleton .gitkeep files)
server-php/writable/cache/*
!server-php/writable/cache/.gitkeep
server-php/writable/logs/*
!server-php/writable/logs/.gitkeep
server-php/writable/session/*
!server-php/writable/session/.gitkeep
server-php/writable/uploads/*
!server-php/writable/uploads/.gitkeep
server-php/writable/debugbar/*

# OS / IDE
.DS_Store
Thumbs.db
*.log
