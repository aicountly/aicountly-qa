# =============================================================================
# SISPL server-php API — environment configuration
#
# IMPORTANT: Copy this file to public_html/api/.env on cPanel after deploy.
# The deploy workflow does NOT upload .env (secrets stay on the server).
# =============================================================================

# --- Application ---
APP_ENV=production
# Long random string for CSRF signing and IP hashing (min 32 chars)
APP_SECRET=replace-with-a-long-random-secret-min-32-characters

# --- PostgreSQL ---
# Use your hosted Postgres host (Supabase, Neon, Railway, RDS, etc.)
DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_NAME=sispl_payments
DB_USER=postgres
DB_PASS=your_postgres_password
# SSL: require | prefer | disable (use require for cloud Postgres)
DB_SSLMODE=require

# --- CORS (frontend origins allowed to call the API) ---
# Comma-separated, no trailing slash.
# Add every partner site that will POST donations to this API. The Razorpay
# merchant lives on sispl.org, but partner NGO sites (e.g. positivetree.ngo,
# aicountly.co.in) call /api/payments directly from the browser and need an
# explicit allow-list.
CORS_ALLOWED_ORIGINS=https://sispl.org,https://www.sispl.org,https://aicountly.github.io,https://aicountly.co.in,https://www.aicountly.co.in,https://positivetree.ngo,https://www.positivetree.ngo

# --- Razorpay ---
# Dashboard → Settings → API Keys
# Test keys start with rzp_test_ ; Live keys start with rzp_live_
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# Dashboard → Settings → Webhooks → secret for https://sispl.org/api/payments/webhook/razorpay
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
# Name shown on Razorpay checkout
RAZORPAY_COMPANY_NAME=SISPL

# --- Payment security & limits ---
# Admin audit report: GET /api/payments/report with header X-Admin-Key
PAYMENT_ADMIN_API_KEY=replace-with-strong-admin-api-key
PAYMENT_RATE_LIMIT_PER_HOUR=20
PAYMENT_MAX_AMOUNT_INR=10000000
PAYMENT_MAX_AMOUNT_USD=100000
