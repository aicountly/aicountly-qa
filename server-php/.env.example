# QA API (CodeIgniter 4.6 — coming soon)
APP_ENV=development
APP_URL=https://qa.aicountly.org/api

# PostgreSQL (QA portal database — not target app DBs)
QA_DB_HOST=127.0.0.1
QA_DB_PORT=5432
QA_DB_NAME=qa_aicountly
