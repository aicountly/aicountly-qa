# AICOUNTLY QA Portal API (CodeIgniter 4.6)
# Copy to .env locally; never commit a real .env.

CI_ENVIRONMENT=production
app.baseURL=https://qa.aicountly.org/api/
app.indexPage=

# PostgreSQL (QA portal database — never target app DBs)
QA_DB_HOST=127.0.0.1
QA_DB_PORT=5432
QA_DB_NAME=qa_aicountly
QA_DB_USER=
QA_DB_PASSWORD=

# Auth & encryption (generate strong random values; never commit real secrets)
# Generate: php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
QA_JWT_SECRET=
QA_JWT_TTL_MINUTES=720
QA_WORKER_TOKEN=

# AES-256-GCM key (32 bytes hex-encoded). Used only by App\Libraries\Vault.
QA_VAULT_KEY=

# Reports storage root (relative to repo root, absolute on server).
QA_REPORTS_DIR=../qa-reports

# Optional: LLM provider for the Session Planner (disabled by default).
QA_LLM_PROVIDER=
QA_LLM_API_KEY=
QA_LLM_MODEL=

# Optional: flow.aicountly.org ticket webhook (disabled by default).
QA_FLOW_WEBHOOK_URL=
QA_FLOW_WEBHOOK_TOKEN=

# CORS — comma-separated origins allowed to call the API.
QA_ALLOWED_ORIGINS=https://qa.aicountly.org,http://localhost:5173

# Console controller SSO (Top Controller identity provider)
CONSOLE_API_URL=https://console.aicountly.org/api
CONTROLLER_APP_CODE=qa

# Optional: initial Owner user (OwnerSeeder — first deploy only)
# QA_OWNER_EMAIL=pno@aicountly.com
# QA_OWNER_NAME=QA Owner
# QA_OWNER_PASSWORD=
