{
  "code": "BKS_019_LEDGERS",
  "name": "Ledger Report",
  "product": "books",
  "module": "Reports",
  "sub_module": "Ledger",
  "severity_on_fail": "high",
  "steps": [
    { "kind": "navigate_menu", "path": ["Reports", "Ledger"] },
    { "kind": "apply_date_filter", "from": "{fy_start}", "to": "{fy_end}" },
    { "kind": "select_ledger", "name": "{QA_RUN_ID} Customer A" },
    { "kind": "read_table",    "selector_options": ["[data-test=ledger-report]", "table"], "key": "ledger_a" },
    { "kind": "expect_close_balance", "from": "ledger_a", "metric_key": "customer_outstanding" }
  ],
  "validations": ["ACC_LEDGER_RECONCILES", "REPORTS_RECONCILE_VOUCHERS", "DATE_FILTER_WORKS"]
}
