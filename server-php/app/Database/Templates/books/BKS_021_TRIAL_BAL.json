{
  "code": "BKS_021_TRIAL_BAL",
  "name": "Trial Balance",
  "product": "books",
  "module": "Reports",
  "sub_module": "Trial Balance",
  "severity_on_fail": "critical",
  "steps": [
    { "kind": "navigate_menu", "path": ["Reports", "Trial Balance"] },
    { "kind": "apply_date_filter", "from": "{fy_start}", "to": "{fy_end}" },
    { "kind": "read_table",    "selector_options": ["[data-test=trial-balance]", "table"], "key": "tb" },
    { "kind": "expect_metric", "metric_key": "tb_debit_total",  "from": "tb", "row_match": "Total" },
    { "kind": "expect_metric", "metric_key": "tb_credit_total", "from": "tb", "row_match": "Total" }
  ],
  "validations": ["ACC_TB_BALANCED", "REPORTS_RECONCILE_VOUCHERS"]
}
