{
  "code": "BKS_022_PNL",
  "name": "Profit & Loss",
  "product": "books",
  "module": "Reports",
  "sub_module": "Profit & Loss",
  "severity_on_fail": "high",
  "steps": [
    { "kind": "navigate_menu", "path": ["Reports", "Profit & Loss"] },
    { "kind": "apply_date_filter", "from": "{fy_start}", "to": "{fy_end}" },
    { "kind": "read_table",    "selector_options": ["[data-test=pnl]", "table"], "key": "pnl" },
    { "kind": "expect_metric", "metric_key": "gross_profit", "from": "pnl", "row_match": "Gross Profit" },
    { "kind": "expect_metric", "metric_key": "net_profit",   "from": "pnl", "row_match": "Net Profit" }
  ],
  "validations": ["PNL_GROSS_PROFIT", "PNL_NET_PROFIT"]
}
