{
  "code": "BKS_020_REGISTERS",
  "name": "Registers",
  "product": "books",
  "module": "Reports",
  "sub_module": "Registers",
  "splittable": true,
  "sub_modules": ["Sales Register", "Purchase Register", "Voucher Register"],
  "severity_on_fail": "high",
  "steps": [
    { "kind": "navigate_menu", "path": ["Reports", "Registers", "Sales Register"] },
    { "kind": "apply_date_filter", "from": "{fy_start}", "to": "{fy_end}" },
    { "kind": "read_table",        "selector_options": ["[data-test=sales-register]", "table"], "key": "sales_register" },
    { "kind": "expect_metric",     "metric_key": "sales_voucher_count", "from": "sales_register" },
    { "kind": "expect_metric",     "metric_key": "taxable_sales",       "from": "sales_register" },

    { "kind": "navigate_menu", "path": ["Reports", "Registers", "Purchase Register"] },
    { "kind": "apply_date_filter", "from": "{fy_start}", "to": "{fy_end}" },
    { "kind": "read_table",        "selector_options": ["[data-test=purchase-register]", "table"], "key": "purchase_register" },
    { "kind": "expect_metric",     "metric_key": "purchase_voucher_count", "from": "purchase_register" },
    { "kind": "expect_metric",     "metric_key": "taxable_purchases",      "from": "purchase_register" }
  ],
  "validations": ["ACC_SALES_REGISTER_MATCH", "ACC_PURCH_REGISTER_MATCH", "REG_VOUCHER_COUNT", "DATE_FILTER_WORKS"]
}
