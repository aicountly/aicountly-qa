{
  "code": "BKS_023_BALANCE_SHEET",
  "name": "Balance Sheet",
  "product": "books",
  "module": "Reports",
  "sub_module": "Balance Sheet",
  "severity_on_fail": "critical",
  "steps": [
    { "kind": "navigate_menu", "path": ["Reports", "Balance Sheet"] },
    { "kind": "apply_date_filter", "from": "{fy_start}", "to": "{fy_end}" },
    { "kind": "read_table",    "selector_options": ["[data-test=balance-sheet]", "table"], "key": "bs" },
    { "kind": "expect_metric", "metric_key": "bs_asset_total",     "from": "bs", "row_match": "(Assets|Total Assets)" },
    { "kind": "expect_metric", "metric_key": "bs_liability_total", "from": "bs", "row_match": "(Liabilit|Total Liabilities)" }
  ],
  "validations": ["BS_BALANCED"]
}
