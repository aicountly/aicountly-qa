# =============================================================================
# aicountly-smoke web (Vite) — environment configuration
# Used at build time by GitHub Actions / local npm run build
# =============================================================================

VITE_APP_NAME=AiCountly Smoke

# Backend API base URL (required for payments on GitHub Pages)
# Production example: https://smoke.aicountly.org/api
VITE_API_URL=https://smoke.aicountly.org/api

# Legacy optional override (Razorpay is handled via API; usually leave empty)
VITE_PAYMENT_URL=
