# AICOUNTLY QA Portal — Playwright Worker
# Copy to .env locally; never commit a real .env.

# Where the QA API lives (CodeIgniter).
QA_API_URL=https://qa.aicountly.org/api

# Worker shared secret (matches QA_WORKER_TOKEN in server-php/.env).
QA_WORKER_TOKEN=

# Unique identifier for this worker host. Defaults to hostname.
QA_WORKER_ID=

# Polling cadence.
QA_POLL_INTERVAL_MS=5000
QA_HEARTBEAT_MS=15000

# Local reports root (where session evidence is written).
QA_REPORTS_DIR=../qa-reports

# Optional: headless mode (1 = headless, 0 = headed for debugging).
QA_HEADLESS=1

# Optional: slow-motion ms between actions (helpful for debugging).
QA_SLOWMO_MS=0
