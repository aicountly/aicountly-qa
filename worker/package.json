{
  "name": "aicountly-qa-worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev":   "tsx watch index.ts",
    "start": "tsx index.ts",
    "qa:basic-check": "tsx index.ts --mode=basic-check",
    "qa:run-session": "tsx index.ts --mode=run-session",
    "qa:books":       "tsx index.ts --mode=books",
    "qa:reports":     "tsx index.ts --mode=reports",
    "qa:validate":    "tsx index.ts --mode=validate",
    "qa:cleanup":     "tsx index.ts --mode=cleanup",
    "playwright:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
